# Copy to .env (or set in your systemd unit) and fill in.
# The poller reads these as defaults; the dashboard can override them at runtime.

# --- Plaud login (one-time, used by plaud-login.ts) ---
PLAUD_EMAIL=you@example.com
PLAUD_PASSWORD=your-plaud-password
PLAUD_REGION=eu                 # eu | us

# --- Poller ---
PLAUD_OUTPUT_DIR=/mnt/nfs/plaud
PLAUD_AUDIO_FORMAT=mp3           # mp3 | original
PLAUD_CHUNK_MINUTES=10           # 0 to disable chunking
PLAUD_POLL_INTERVAL_MIN=5
PLAUD_DATA_DIR=/opt/plaud-toolkit/data
PLAUD_CONFIG_DIR=/home/plaud/.plaud

# --- Dashboard ---
PLAUD_GUI_PORT=8787
PLAUD_GUI_USER=admin
PLAUD_GUI_PASSWORD=change-me     # leave empty to disable auth (LAN/VPN only!)
